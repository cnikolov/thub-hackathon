# Copy to .env.local and fill in values

# Gemini API key — only needed if using the direct browser-to-Gemini fallback
# (the Fishjam agent path handles Gemini server-side so this is optional)
# VITE_GEMINI_API_KEY=

# Fishjam ID is returned by the API when creating an interview session.
# No frontend env var needed for Fishjam — it comes from the server.

# Interview session logging (set to "true" to enable)
# VITE_INTERVIEW_LOG=true
